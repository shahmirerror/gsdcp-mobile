{
  "expo": {
    "name": "GSDCP",
    "slug": "gsdcp-mobile",
    "version": "1.0.1",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo-landscape.png",
      "backgroundColor": "#FFFFFF",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gsdcp.ccms.inspedium",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to take a new profile photo.",
        "NSPhotoLibraryUsageDescription": "Used to select a profile photo from your library.",
        "NSPhotoLibraryAddUsageDescription": "Used to save photos to your library.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.gsdcp.ccms.inspedium",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "scheme": "gsdcp",
    "extra": {
      "errorReporting": {
        "supportEmail": "your-email@example.com",
        "webhookUrl": "https://gsdcp.org/api/mobile/report-error"
      },
      "eas": {
        "projectId": "8bc67d8f-a681-4816-987d-3f6e3d6250ae"
      }
    },
    "plugins": [
      "expo-dev-client",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Used to select a profile photo from your library.",
          "cameraPermission": "Used to take a new profile photo.",
          "microphonePermission": false
        }
      ],
      "./plugins/withBlockedMediaPermissions.js",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0F5C3A",
          "sounds": []
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      "react-native-edge-to-edge"
    ],
    "owner": "shahmir-sindhus-organization"
  }
}
