{
  "expo": {
    "name": "GSDCP",
    "slug": "gsdcp-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#0F5C3A",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "org.gsdcp.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F5C3A"
      },
      "package": "org.gsdcp.mobile"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "scheme": "gsdcp"
  }
}
