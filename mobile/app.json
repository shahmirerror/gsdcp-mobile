{
  "expo": {
    "name": "GSDCP",
    "slug": "gsdcp-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo-landscape.png",
      "backgroundColor": "#FFFFFF",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "org.gsdcp.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to take a new profile photo.",
        "NSPhotoLibraryUsageDescription": "Used to select a profile photo from your library.",
        "NSPhotoLibraryAddUsageDescription": "Used to save photos to your library.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "org.gsdcp.mobile",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "scheme": "gsdcp",
    "extra": {
      "eas": {
        "projectId": "8bc67d8f-a681-4816-987d-3f6e3d6250ae"
      }
    },
    "plugins": [
      "expo-dev-client",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Used to select a profile photo from your library.",
          "cameraPermission": "Used to take a new profile photo."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0F5C3A",
          "sounds": []
        }
      ]
    ],
    "owner": "shahmir-sindhus-organization"
  }
}
