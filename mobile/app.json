{
  "expo": {
    "name": "GSDCP",
    "slug": "gsdcp-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo-landscape.png",
      "backgroundColor": "#FFFFFF",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "org.gsdcp.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F5C3A"
      },
      "package": "org.gsdcp.mobile"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "scheme": "gsdcp",
    "extra": {
      "eas": {
        "projectId": "1dbe2f8d-6c82-4071-b167-9e6e4d4621a4"
      }
    },
    "plugins": [
      "expo-font"
    ]
  }
}
